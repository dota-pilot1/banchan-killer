flowchart TD
    A["상품 상세/카테고리 페이지에서 상품 확인"] --> B["장바구니 담기"]
    B --> C{"상품 상태 확인"}
    C -->|SALE| D["장바구니 목록 조회"]
    C -->|SOLDOUT 또는 HIDDEN| X1["담기 실패 안내"]

    D --> E["수량 변경 / 상품 삭제"]
    E --> F["주문하기 클릭"]
    F --> G["주문서 페이지 진입"]

    G --> H["주문자 정보 확인"]
    H --> I["수령인/배송지 입력"]
    I --> J["주문 상품/수량/금액 확인"]
    J --> K{"주문 생성 가능 여부 확인"}

    K -->|재고 충분 / 상태 정상| L["주문 생성"]
    K -->|재고 부족 또는 상태 변경| X2["주문 생성 실패 안내"]

    L --> M["orders / order_items 저장"]
    M --> N["주문 상태 = PENDING_PAYMENT"]
    N --> O["결제창 호출"]

    O --> P{"결제 진행 결과"}
    P -->|사용자 취소| X3["결제 중단 / 주문 유지 또는 만료 처리"]
    P -->|결제 실패| X4["결제 실패 / 재시도 안내"]
    P -->|결제 완료| Q["프론트가 paymentKey, orderId, amount 전달"]

    Q --> R["백엔드에서 PG 승인 API 호출"]
    R --> S{"승인 검증"}
    S -->|실패| X5["결제 검증 실패 / 주문 유지 / 실패 처리"]
    S -->|성공| T["payments 저장"]

    T --> U["주문 상태 = PAID"]
    U --> V["재고 차감"]
    V --> W["주문 완료 화면 표시"]
    W --> Y["내 주문 목록/상세 조회 가능"]

    Y --> Z["관리자 주문 관리 화면 조회"]
    Z --> AA["주문 상태 = PREPARING"]
    AA --> AB["주문 상태 = SHIPPED"]
    AB --> AC["주문 상태 = DELIVERED"]

    U --> AD{"취소/환불 요청?"}
    AD -->|아니오| Z
    AD -->|예| AE{"배송 전인가?"}
    AE -->|예| AF["결제 취소/환불 승인"]
    AF --> AG["주문 상태 = CANCELLED 또는 REFUNDED"]
    AG --> AH["재고 복원 여부 처리"]
    AH --> Y
    AE -->|아니오| AI["고객센터/관리자 확인 후 별도 처리"]

    style X1 fill:#fff1f2,stroke:#ef4444,color:#7f1d1d
    style X2 fill:#fff1f2,stroke:#ef4444,color:#7f1d1d
    style X3 fill:#fff7ed,stroke:#f97316,color:#7c2d12
    style X4 fill:#fff1f2,stroke:#ef4444,color:#7f1d1d
    style X5 fill:#fff1f2,stroke:#ef4444,color:#7f1d1d
